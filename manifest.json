{
  "manifest_version": 2,
  "name": "Gemini Cleaner",
  "version": "1.0.0",
  "description": "Hide \"Upgrade to Ultra\" ads and banners on Gemini for a cleaner AI experience.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gemini-cleaner@extension",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "https://gemini.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
